# --- Requerido para el agente (chat con Gemini) ---
GOOGLE_API_KEY=

# --- Modelo (opcional; por defecto gemini-3-flash-preview) ---
# MAIN_AGENT_MODEL=gemini-3-flash-preview

# --- Workspace del agente (opcional en dev; por defecto process.cwd()) ---
# Ruta absoluta al directorio que el agente puede leer y buscar.
# AGENT_WORKSPACE_ROOT=C:\ruta\a\tu\proyecto

# --- Límites del agente (opcional) ---
# AGENT_MAX_FILE_BYTES=512000
# AGENT_MAX_TOOL_OUTPUT_CHARS=32000
# AGENT_MAX_AGENT_STEPS=24
# AGENT_SEARCH_MAX_FILES=400
# AGENT_SEARCH_MAX_MATCHES=80

# --- Depuración: incluir steps completos en JSON de /api/agent/chat ---
# AGENT_DEBUG_STEPS=true

# --- Otros (usados en config; el entrypoint puede ignorar PORT aún) ---
# PORT=3000
# BASE_URL=http://localhost:3000
