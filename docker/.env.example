# Copiar a la raíz del monorepo como `.env` para `docker compose` (Compose carga `.env` automáticamente).

GOOGLE_API_KEY=

# Repo Git público (HTTPS). Ejemplo:
# REPO_URL=https://github.com/vercel/next.js.git
REPO_URL=

# Opcional: rama o tag
# REPO_REF=canary

# true = borra el volumen de trabajo y vuelve a clonar en cada arranque (útil para forzar actualización)
# FORCE_REPO_REFRESH=false
